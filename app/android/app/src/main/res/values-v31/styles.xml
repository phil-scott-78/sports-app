<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ replaces the windowBackground splash with the system splash
     screen (centered launcher icon on a solid color). Match it to the app's
     broadcast-dark background; the icon's own #111318 background disappears
     into it, so only the scorebug mark shows. -->
<resources>
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowSplashScreenBackground">@color/launch_background</item>
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@color/launch_background</item>
    </style>
</resources>
